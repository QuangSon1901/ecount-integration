# Server Configuration
NODE_ENV=development
PORT=3000
API_KEY=dev-api-key-2024

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=yunexpress_integration
DB_USER=root
DB_PASSWORD=your_password

TZ=Asia/Ho_Chi_Minh

# YunExpress Configuration
YUNEXPRESS_BASE_URL=https://openapi-sbx.yunexpress.cn
YUNEXPRESS_APP_ID=your-app-id
YUNEXPRESS_APP_SECRET=your-app-secret
YUNEXPRESS_SOURCE_KEY=your-source-key

# ECount Configuration
ECOUNT_COMPANY_CODE=
ECOUNT_ID=
ECOUNT_PASSWORD=
ECOUNT_BASE_URL=

# ECount POD Account (separate from Express)
ECOUNT_POD_COMPANY_CODE=
ECOUNT_POD_ID=
ECOUNT_POD_PASSWORD=
ECOUNT_POD_BASE_URL=
ECOUNT_POD_API_CERT_KEY=
ECOUNT_POD_ZONE=

# ONOS POD
ONOS_BASE_URL=https://api-app.onospod.com/api/v1
ONOS_EMAIL=
ONOS_PASSWORD=
ONOS_WEBHOOK_SECRET=

# S2BDIY
S2BDIY_BASE_URL=http://openapi.s2bdiy.com/open
S2BDIY_APP_KEY=
S2BDIY_APP_SECRET=

# Printposs
PRINTPOSS_BASE_URL=https://api.printposs.com
PRINTPOSS_API_KEY=
PRINTPOSS_WEBHOOK_SECRET=

# Puppeteer Configuration
PUPPETEER_HEADLESS=false
PUPPETEER_TIMEOUT=40000

# Cron Configuration
CRON_TRACKING_ENABLED=true
CRON_TRACKING_SCHEDULE=*/30 * * * *
CRON_UPDATE_ERP_ENABLED=true

# Logging
LOG_LEVEL=debug

# Authentication & Session
# Secret key for signing session cookies (CHANGE IN PRODUCTION!)
APP_SESSION_SECRET=thg-session-secret-change-in-prod

# Admin User Setup
# After setting up the app, create admin user with:
# node scripts/create-admin.js <username> <password> [full_name] [email]
# Example: node scripts/create-admin.js admin admin123 "Admin User" admin@example.com

# ─── ITC Label Aggregator (Phase 5) ─────────────────────────────────
# Used to buy shipping labels for OMS orders.
ITC_BASE_URL=
ITC_API_KEY=
ITC_DEFAULT_SERVICE=USPS_GROUND_ADVANTAGE
ITC_TIMEOUT_MS=30000

# Origin/shipper (your warehouse) — sent on every ITC create-order
ITC_SHIPPER_NAME=THG Logistics
ITC_SHIPPER_PHONE=
ITC_SHIPPER_EMAIL=
ITC_SHIPPER_COUNTRY=US
ITC_SHIPPER_STATE=
ITC_SHIPPER_CITY=
ITC_SHIPPER_POSTAL_CODE=
ITC_SHIPPER_ADDRESS_LINE1=
ITC_SHIPPER_ADDRESS_LINE2=